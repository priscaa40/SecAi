# Required. Use a Singapore-region pay-as-you-go Model Studio key; SecAi calls
# the Singapore dashscope-intl endpoint. Token/Coding Plan keys are not for this backend.
DASHSCOPE_API_KEY=replace-with-singapore-pay-as-you-go-model-studio-key
# Serverless Alibaba Cloud RDS for PostgreSQL. Use its internal endpoint and
# URL-encode password special characters. This example does not require RDS SSL.
DATABASE_URL=postgresql://secai_app:URL_ENCODED_PASSWORD@YOUR_RDS_INTERNAL_ENDPOINT:5432/secai?sslmode=disable&connect_timeout=10

# Required for the deployed Control ECS EIP routed by Caddy. The dashboard and
# API share one HTTPS origin; Caddy routes API paths internally.
PUBLIC_BASE_URL=https://CONTROL_PUBLIC_IP
FRONTEND_BASE_URL=https://CONTROL_PUBLIC_IP
# Host Caddy reaches the loopback-published API through Docker's private bridge.
# Keep port 8000 bound to host 127.0.0.1 when trusting this range.
SECAI_TRUSTED_PROXY_CIDRS=172.16.0.0/12,127.0.0.1/32,::1/128

# Required for Alibaba SLS discovery and security-group actions
# Exact name of the RAM role attached to Control ECS.
ALIBABA_CLOUD_ECS_METADATA=secai-control-runtime
# Full ARN of that same provider role. Customers grant this exact principal
# temporary access to their own Alibaba accounts.
SECAI_ALIBABA_PROVIDER_ROLE_ARN=acs:ram::YOUR_SECAI_ACCOUNT_ID:role/secai-control-runtime

# Recommended deployment settings. Qwen uses qwen-plus and the code defaults
# unless you deliberately add model/tuning overrides.
SECAI_SLS_POLL_INTERVAL_SECONDS=30
# Public networks SecAi must never block, comma-separated. Do not use 0.0.0.0/0.
SECAI_REMEDIATION_PROTECTED_CIDRS=

# Optional Discord integration. Supply all three values, configure the public
# interactions endpoint, and keep automatic command registration enabled.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_APPLICATION_PUBLIC_KEY=
DISCORD_AUTO_REGISTER_COMMANDS=true

# Reproducible judge tenant. These values stay in the API container and are not
# written to the frontend runtime configuration.
SECAI_JUDGE_MODE=false
SECAI_JUDGE_EMAIL=
SECAI_JUDGE_PASSWORD=
SECAI_JUDGE_ALIBABA_ROLE_ARN=acs:ram::DEMO_CUSTOMER_ACCOUNT_ID:role/secai-judge-site
SECAI_JUDGE_ALIBABA_EXTERNAL_ID=
SECAI_JUDGE_ALIBABA_REGION=ap-southeast-1
SECAI_JUDGE_SECURITY_GROUP_ID=sg-replace-with-the-dedicated-demo-storefront-group
SECAI_JUDGE_SLS_ENDPOINT=ap-southeast-1.log.aliyuncs.com
SECAI_JUDGE_SLS_PROJECT=
SECAI_JUDGE_SLS_LOGSTORE=
