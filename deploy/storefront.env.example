# Public URL of the SecAi API on the control ECS.
SECAI_PUBLIC_BASE_URL=https://CONTROL_PUBLIC_IP

# Use judge-site for the prepared judge deployment. For normal onboarding, use
# the site_... identifier returned after creating the website in SecAi.
SECAI_SITE_ID=judge-site

# The host Caddy process is the only proxy directly connected to the app.
SECAI_TRUSTED_PROXY_CIDRS=127.0.0.1/32
