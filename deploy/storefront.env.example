# Public URL of the SecAi API on the control ECS.
SECAI_PUBLIC_BASE_URL=https://sec-ai.duckdns.org

# Set this only when Website monitoring script was selected. Paste the site_...
# identifier from the generated browser snippet. Leave it empty for Alibaba Cloud.
SECAI_SITE_ID=

# The host Caddy process is the only proxy directly connected to the app.
SECAI_TRUSTED_PROXY_CIDRS=127.0.0.1/32
